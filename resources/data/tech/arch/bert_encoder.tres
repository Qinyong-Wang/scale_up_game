research_cost = 0
research_months = 24
effects = {
	&"train_coef": 1.3,
	&"inference_coef": 1.0,
	&"capability_coef": 1.0,
}
effects_summary = "训练 ×1.3 · 评分上限 30"
min_researchers = 2
min_engineers = 1
min_gpu_count = 16
capability_cap = 30.0
