research_cost = 0
research_months = 48
effects = {
	&"train_coef": 1.4,
	&"inference_coef": 1.0,
}
effects_summary = "训练 ×56 · 推理 ×40 (1/40 激活, 前沿)"
min_researchers = 5
min_engineers = 10
min_gpu_count = 500
