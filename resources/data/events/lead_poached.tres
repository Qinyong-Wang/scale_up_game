[gd_resource type="Resource" script_class="EventCard" load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/resources/event_card.gd" id="1_ec"]
[ext_resource type="Script" path="res://scripts/resources/event_option.gd" id="2_eo"]
[ext_resource type="Script" path="res://scripts/resources/event_effect.gd" id="3_ef"]

[sub_resource type="Resource" id="eff_0"]
script = ExtResource("3_ef")
kind = &"economy_spend"
params = {"pct": 0.04, "floor": 10000, "cap": 30000000}

[sub_resource type="Resource" id="opt_retain"]
script = ExtResource("2_eo")
id = &"retain"
label = "加薪挽留, 稳住市场信心"
effects = [SubResource("eff_0")]

[sub_resource type="Resource" id="eff_1"]
script = ExtResource("3_ef")
kind = &"product_boost_subscribers"
params = {"pct": -0.06, "floor": 40, "cap": 150000000}

[sub_resource type="Resource" id="opt_let_go"]
script = ExtResource("2_eo")
id = &"let_go"
label = "不跟价, 承受市场信心波动"
effects = [SubResource("eff_1")]

[resource]
script = ExtResource("1_ec")
id = &"lead_poached"
category = &"crisis"
title = "对手公开挖角你的核心 lead"
body = "竞争对手开出三倍年薪, 挖角传闻已经传到客户耳朵里。大家都在看你是加薪稳住军心, 还是不跟价、让市场自己消化这条新闻。"
min_turn = 4
requires_lead_min = 1
requires_product = true
weight = 10
cooldown_months = 20
options = [SubResource("opt_retain"), SubResource("opt_let_go")]
