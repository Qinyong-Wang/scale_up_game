[gd_resource type="Resource" script_class="EventCard" load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/resources/event_card.gd" id="1_ec"]
[ext_resource type="Script" path="res://scripts/resources/event_option.gd" id="2_eo"]
[ext_resource type="Script" path="res://scripts/resources/event_effect.gd" id="3_ef"]

[sub_resource type="Resource" id="eff_0"]
script = ExtResource("3_ef")
kind = &"dataset_delete"
params = {}

[sub_resource type="Resource" id="opt_comply"]
script = ExtResource("2_eo")
id = &"comply"
label = "配合整改, 删除存疑数据集"
effects = [SubResource("eff_0")]

[sub_resource type="Resource" id="eff_1"]
script = ExtResource("3_ef")
kind = &"economy_spend"
params = {"pct": 0.05, "floor": 15000, "cap": 50000000}

[sub_resource type="Resource" id="opt_lawyer"]
script = ExtResource("2_eo")
id = &"lawyer"
label = "花钱请律师团摆平"
effects = [SubResource("eff_1")]

[resource]
script = ExtResource("1_ec")
id = &"data_audit"
category = &"crisis"
title = "监管上门检查数据合规"
body = "监管机构突击检查, 对你的部分数据集来源提出了质疑。"
min_turn = 4
requires_dataset_min = 1
weight = 10
cooldown_months = 20
options = [SubResource("opt_comply"), SubResource("opt_lawyer")]
