[gd_resource type="Resource" script_class="EventCard" load_steps=7 format=3]

[ext_resource type="Script" path="res://scripts/resources/event_card.gd" id="1_ec"]
[ext_resource type="Script" path="res://scripts/resources/event_option.gd" id="2_eo"]
[ext_resource type="Script" path="res://scripts/resources/event_effect.gd" id="3_ef"]

[sub_resource type="Resource" id="eff_0"]
script = ExtResource("3_ef")
kind = &"economy_spend"
params = {"pct": 0.05, "floor": 12000, "cap": 50000000}

[sub_resource type="Resource" id="opt_pay"]
script = ExtResource("2_eo")
id = &"pay"
label = "加价采购保供应"
effects = [SubResource("eff_0")]

[sub_resource type="Resource" id="opt_wait"]
script = ExtResource("2_eo")
id = &"wait"
label = "暂缓扩容, 先扛着"
effects = []

[resource]
script = ExtResource("1_ec")
id = &"gpu_shortage"
category = &"crisis"
title = "全球 GPU 缺货, 供应商坐地起价"
body = "上游产能紧张, 供应商把显卡报价翻了一倍, 还说要排队。"
min_turn = 4
requires_datacenter = true
weight = 10
cooldown_months = 20
options = [SubResource("opt_pay"), SubResource("opt_wait")]
